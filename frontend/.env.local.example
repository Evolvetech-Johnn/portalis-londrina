# ── Supabase (Server-side — NUNCA exponha ao browser) ───────────────────────
# Usadas apenas pelas Vercel Serverless Functions em /api/
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9... (service_role key do painel Supabase)

# ── CORS ─────────────────────────────────────────────────────────────────────
# Em produção, substitua pela URL real do seu domínio Vercel
FRONTEND_URL=https://portalis.vercel.app

# ── Cloudinary (assets estáticos) ────────────────────────────────────────────
# Usado pelo componente OptimizedImage.jsx no frontend (prefixo VITE_ = exposto ao browser)
VITE_CLOUDINARY_CLOUD_NAME=seu_cloud_name
